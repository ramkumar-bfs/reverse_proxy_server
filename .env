REVERSE_PROXY_HOST="127.0.0.1"
REVERSE_PROXY_PORT=8080
REVERSE_PROXY_MODE="development"  # Options: development, production
PYTHONPATH=C:\Users\ramkumar\Documents\development\reverse_proxy_server\src



# ── Required ──────────────────────────────────────────────────────────────────
# The upstream ShotGrid server this proxy forwards all requests to.
TARGET_API_BASE_URL=http://192.168.1.24:8282

# ── Upstream auth (optional) ──────────────────────────────────────────────────
# Injected into every outbound request to ShotGrid.
# Use ONE of the following auth methods — leave the rest blank.

# Option A: Bearer token or Basic auth
# UPSTREAM_AUTHORIZATION=Bearer <token>

# Option B: Session cookie
# UPSTREAM_COOKIE=sessionid=<value>

# Option C: Custom API key header
# UPSTREAM_API_KEY_HEADER=X-Sg-Api-Key
# UPSTREAM_API_KEY_VALUE=<your_api_key>

# ── Proxy self-auth (optional) ────────────────────────────────────────────────
# If set, clients must send this value in the X-Proxy-Api-Key header.
# Leave blank to rely on network/firewall access control alone.
# PROXY_API_KEY=change-me-to-a-strong-random-secret

# ── Timeouts (seconds) ────────────────────────────────────────────────────────
CONNECT_TIMEOUT=10
READ_TIMEOUT=60
WRITE_TIMEOUT=30
POOL_TIMEOUT=10

# ── Connection pool ───────────────────────────────────────────────────────────
MAX_CONNECTIONS=100
MAX_KEEPALIVE_CONNECTIONS=30
KEEPALIVE_EXPIRY=30

# ── Retry ─────────────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_MIN_WAIT=0.5
RETRY_MAX_WAIT=5.0

# ── Rate limiting (requests per minute per client IP) ─────────────────────────
RATE_LIMIT_PER_MINUTE=300

# ── Body size limit (bytes) ───────────────────────────────────────────────────
# Default is 512 MB (536870912 bytes) to support ShotGrid media uploads.
MAX_BODY_BYTES=536870912
